# ── API Configuration ──────────────────────────────────────────────────────────
#
# Base URL for all API requests.
#
# Leave this unset (or commented out) during local development:
# the app will use Next.js internal routes at /api/* (same-origin).
#
# Set this variable when pointing to an external backend (staging, production).
# Do NOT include a trailing slash.
#
# Examples:
#   NEXT_PUBLIC_API_URL=https://api.repaircafe.fr
#   NEXT_PUBLIC_API_URL=http://localhost:3001/api
#
# NEXT_PUBLIC_API_URL=
